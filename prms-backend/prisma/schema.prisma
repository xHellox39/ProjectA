// PRMS Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id              String   @id @default(uuid())
  firebase_uid    String   @unique
  email           String?  @unique
  passwordHash    String?
  full_name       String?
  phone           String?
  profile_img_url String?
  refreshToken    String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  UserRole    UserRole[]
  properties  Property[]
  tickets     MaintenanceTicket[]
  bookings       Booking[]
  sentMessages   Message[]    @relation("sender")
  receivedMessages Message[] @relation("receiver")
  payments       Payment[]
  invoices    Invoice[]
  notifications Notification[]
  favorites   Favorite[]
  auditLogs   AuditLog[]

  @@index([email])
  @@map("users")
}

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users UserRole[]
  @@map("roles")
}

model UserRole {
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Property {
  id             String    @id @default(uuid())
  title          String
  address        String
  property_type  String    @default("apartment")
  rent           Float
  status         PropertyStatus  @default(AVAILABLE)
  availableFrom  DateTime?
  availableTo    DateTime?
  city           String?
  state          String?
  ownerId        String
  owner          User      @relation(fields: [ownerId], references: [id])
  amenities      Amenity[]
  images         PropertyImage[]
  bookings       Booking[]
  invoices       Invoice[]
  favorites      Favorite[]

  @@index([ownerId])
  @@map("properties")
}

model Amenity {
  id             String   @id @default(uuid())
  name           String
  description    String?
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@map("amenities")
}

model PropertyImage {
  id             String   @id @default(uuid())
  url            String
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@map("property_images")
}

model Booking {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id])
  start_date     DateTime
  end_date       DateTime
  status         BookingStatus   @default(PENDING)
  totalAmount    Float?
  paymentStatus  PaymentStatus   @default(UNPAID)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  payments       Payment[]
  invoices       Invoice[]

  @@index([userId])
  @@index([propertyId])
  @@map("bookings")
}

model Payment {
  id             String   @id @default(uuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  amount         Float
  type           String   @default("rent")
  method         String   @default("cash")
  status         PaymentStatus @default(PENDING)
  due_date       DateTime
  paid_at        DateTime?
  reference      String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([userId])
  @@map("payments")
}

model Invoice {
  id             String   @id @default(uuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id])
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  amount         Float
  status         PaymentStatus @default(PENDING)
  due_date       DateTime
  issue_date     DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([userId])
  @@map("invoices")
}

model MaintenanceTicket {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  propertyId     String?
  title          String
  description    String
  status         MaintenanceStatus @default(OPEN)
  priority       MaintenancePriority @default(MEDIUM)
  assignedTo     String?
  resolved_at    DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@map("maintenance_tickets")
}

model Message {
  id             String   @id @default(uuid())
  senderId       String
  sender         User     @relation("sender", fields: [senderId], references: [id])
  receiverId     String
  receiver       User     @relation("receiver", fields: [receiverId], references: [id])
  content        String
  conversationId String
  isRead         Boolean  @default(false)
  created_at     DateTime @default(now())

  @@index([conversationId])
  @@map("messages")
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  type           String
  title          String
  message        String
  isRead         Boolean  @default(false)
  created_at     DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  category    String   @default("general")
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  @@map("system_settings")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  created_at  DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@map("audit_logs")
}

model Favorite {
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  created_at     DateTime @default(now())

  @@id([userId, propertyId])
  @@map("favorites")
}
