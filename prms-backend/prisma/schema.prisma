// This is your Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String   @id @default(uuid())
  firebase_uid       String   @unique
  email              String?
  full_name          String?
  phone              String?
  profile_img_url    String?
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  UserRole           UserRole[]
  properties         Property[]
  tickets            MaintenanceTicket[]
  bookings           Booking[]
  messages           Message[]
}

model Role {
  id     String @id @default(uuid())
  name   String @unique
  users  UserRole[]
}

model UserRole {
  userId String
  user   User @relation(fields: [userId], references: [id])
  roleId String
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Property {
  id             String   @id @default(uuid())
  title          String
  address        String
  property_type  String   @default("apartment")
  rent           Float
  city           String?
  state          String?
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])
  amenities      Amenity[]
  images         PropertyImage[]
  bookings       Booking[]
}

model Amenity {
  id             String   @id @default(uuid())
  name           String
  description    String?
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id])
}

model PropertyImage {
  id             String   @id @default(uuid())
  url            String
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id])
}

model Booking {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id])
  start_date     DateTime
  end_date       DateTime
  status         String   @default("pending")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model MaintenanceTicket {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  propertyId     String?
  description    String
  status         String   @default("open")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model Message {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  content        String
  created_at     DateTime @default(now())
}
